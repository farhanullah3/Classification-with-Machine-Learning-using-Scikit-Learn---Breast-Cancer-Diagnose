n      <td>0.2575</td>\n      <td>0.6638</td>\n      <td>0.17300</td>\n    </tr>\n    <tr>\n      <th>4</th>\n      <td>1</td>\n      <td>20.29</td>\n      <td>14.34</td>\n      <td>135.10</td>\n      <td>1297.0</td>\n      <td>0.10030</td>\n      <td>0.13280</td>\n      <td>0.1980</td>\n      <td>0.10430</td>\n      <td>0.1809</td>\n      <td>...</td>\n      <td>22.54</td>\n      <td>16.67</td>\n      <td>152.20</td>\n      <td>1575.0</td>\n      <td>0.1374</td>\n      <td>0.2050</td>\n      <td>0.4000</td>\n      <td>0.1625</td>\n      <td>0.2364</td>\n      <td>0.07678</td>\n    </tr>\n  </tbody>\n</table>\n<p>5 rows × 31 columns</p>\n</div>"},"metadata":{}}],"execution_count":17},{"id":"dbe2d09d","cell_type":"markdown","source":"---\n## 5.  Feature Engineering\n\nAll 30 numeric measurement columns are kept as features. Each one summarizes a distinct\ngeometric or textural property of the cell nuclei (mean, standard error, and worst\nvalue), and the EDA above showed clear separation on several of them — there's no\nstrong case for dropping any at this stage. Aggressive feature selection is flagged as\na future improvement rather than done here, so results stay easy to reason about.\n\n### 5.1 Define Features (`X`) and Target (`y`)","metadata":{}},{"id":"cbc4535f","cell_type":"code","source":"X = df_clean.drop(columns=[\"diagnosis\"])\ny = df_clean[\"diagnosis\"]\n\nprint(\"Feature matrix X:\", X.shape)\nprint(\"Target vector y :\", y.shape)\nprint(f\"Positive class (malignant) rate: {y.mean():.2%}\")","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:12:55.627617Z","iopub.execute_input":"2026-07-16T12:12:55.627942Z","iopub.status.idle":"2026-07-16T12:12:55.635032Z","shell.execute_reply.started":"2026-07-16T12:12:55.627914Z","shell.execute_reply":"2026-07-16T12:12:55.634137Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Feature matrix X: (569, 30)\nTarget vector y : (569,)\nPositive class (malignant) rate: 37.26%\n","output_type":"stream"}],"execution_count":18},{"id":"3e1fcc5d","cell_type":"markdown","source":"---\n## 6.  Train / Test Split\n\nWe hold out **20%** of the data for testing, using `stratify=y` so both the train and\ntest sets preserve the same malignant/benign ratio as the full dataset.","metadata":{}},{"id":"b9b0cb36","cell_type":"code","source":"X_train, X_test, y_train, y_test = train_test_split(\n    X, y, test_size=0.2, random_state=RANDOM_STATE, stratify=y\n)\n\nprint(f\"Training set: {X_train.shape[0]:,} rows  |  Malignant rate: {y_train.mean():.2%}\")\nprint(f\"Test set    : {X_test.shape[0]:,} rows  |  Malignant rate: {y_test.mean():.2%}\")","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:02.656382Z","iopub.execute_input":"2026-07-16T12:13:02.656763Z","iopub.status.idle":"2026-07-16T12:13:02.665641Z","shell.execute_reply.started":"2026-07-16T12:13:02.656723Z","shell.execute_reply":"2026-07-16T12:13:02.664807Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Training set: 455 rows  |  Malignant rate: 37.36%\nTest set    : 114 rows  |  Malignant rate: 36.84%\n","output_type":"stream"}],"execution_count":19},{"id":"baa313d6","cell_type":"markdown","source":"---\n## 7.  Feature Scaling\n\nOur 30 features live on very different scales (e.g., `area_mean` ranges into the\nthousands while `smoothness_mean` is a small fraction). This matters a lot for some\nalgorithms and not at all for others:\n\n- **Logistic Regression** — uses gradient-based optimization; unscaled features with\n  large ranges dominate the loss surface and slow (or distort) convergence.\n- **KNN** — distance-based; a feature like `area_mean` would completely dominate the\n  Euclidean distance calculation over something like `smoothness_mean` if left unscaled.\n- **SVM** — the margin-maximizing objective is scale-sensitive in exactly the same way.\n- **Decision Tree, Random Forest, Naive Bayes** — largely scale-invariant (trees split\n  on thresholds per feature independently; Naive Bayes models per-feature\n  distributions), so scaling doesn't hurt them but isn't strictly necessary either.\n\nWe apply **`StandardScaler`** (zero mean, unit variance) to all models for consistency —\nfit only on the training set to avoid leaking test-set information.","metadata":{}},{"id":"f12a7a11","cell_type":"code","source":"scaler = StandardScaler()\n\nX_train_scaled = pd.DataFrame(\n    scaler.fit_transform(X_train), columns=X_train.columns, index=X_train.index\n)\nX_test_scaled = pd.DataFrame(\n    scaler.transform(X_test), columns=X_test.columns, index=X_test.index\n)\n\nprint(\" Features scaled. Example — before vs. after for 'area_mean':\")\nprint(f\"   Before: mean={X_train['area_mean'].mean():.2f}, std={X_train['area_mean'].std():.2f}\")\nprint(f\"   After : mean={X_train_scaled['area_mean'].mean():.2f}, std={X_train_scaled['area_mean'].std():.2f}\")","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:12.058303Z","iopub.execute_input":"2026-07-16T12:13:12.058846Z","iopub.status.idle":"2026-07-16T12:13:12.071132Z","shell.execute_reply.started":"2026-07-16T12:13:12.058815Z","shell.execute_reply":"2026-07-16T12:13:12.070315Z"},"trusted":true},"outputs":[{"name":"stdout","text":" Features scaled. Example — before vs. after for 'area_mean':\n   Before: mean=659.58, std=360.42\n   After : mean=-0.00, std=1.00\n","output_type":"stream"}],"execution_count":20},{"id":"5bc8b1ba","cell_type":"markdown","source":"---\n## 8.  Reusable Model Evaluation Function\n\nEvery model below is passed through **one shared function** that fits, predicts, scores,\nand reports — guaranteeing an identical, fair evaluation process across all six\nalgorithms.","metadata":{}},{"id":"fee2ea7c","cell_type":"code","source":"results = []  # collects one dict per model\nfitted_models = {}  # keep fitted models around for plotting later\n\ndef evaluate_model(model, model_name, X_train, X_test, y_train, y_test, results_list=results):\n    '''\n    Fit a classifier, evaluate it on the test set with a full metric suite,\n    print a clean summary, and append the results to `results_list`.\n\n    Returns\n    -------\n    fitted_model : the trained estimator\n    y_pred       : class predictions on X_test\n    y_proba      : predicted probability of the positive class (malignant)\n    metrics      : dict of computed metrics\n    '''\n    # 1. Fit\n    model.fit(X_train, y_train)\n\n    # 2. Predict\n    y_pred = model.predict(X_test)\n    y_proba = model.predict_proba(X_test)[:, 1] if hasattr(model, \"predict_proba\") else y_pred\n\n    # 3. Metrics\n    accuracy = accuracy_score(y_test, y_pred)\n    precision = precision_score(y_test, y_pred)\n    recall = recall_score(y_test, y_pred)\n    f1 = f1_score(y_test, y_pred)\n    roc_auc = roc_auc_score(y_test, y_proba)\n    cm = confusion_matrix(y_test, y_pred)\n\n    metrics = {\n        \"Model\": model_name, \"Accuracy\": accuracy, \"Precision\": precision,\n        \"Recall\": recall, \"F1 Score\": f1, \"ROC-AUC\": roc_auc,\n    }\n    results_list.append(metrics)\n    fitted_models[model_name] = model\n\n    # 4. Pretty print\n    print(f\"📌 {model_name}\")\n    print(f\"   Accuracy  : {accuracy:.4f}\")\n    print(f\"   Precision : {precision:.4f}\")\n    print(f\"   Recall    : {recall:.4f}\")\n    print(f\"   F1 Score  : {f1:.4f}\")\n    print(f\"   ROC-AUC   : {roc_auc:.4f}\")\n    print(f\"   Confusion Matrix:\\n{cm}\")\n    print(\"-\" * 50)\n\n    return model, y_pred, y_proba, metrics\n\nprint(\" Evaluation function ready.\")","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:22.506348Z","iopub.execute_input":"2026-07-16T12:13:22.50712Z","iopub.status.idle":"2026-07-16T12:13:22.515351Z","shell.execute_reply.started":"2026-07-16T12:13:22.507088Z","shell.execute_reply":"2026-07-16T12:13:22.514369Z"},"trusted":true},"outputs":[{"name":"stdout","text":" Evaluation function ready.\n","output_type":"stream"}],"execution_count":22},{"id":"9bd55738","cell_type":"markdown","source":"---\n## 9.  Model Training\n\nSix classifiers, trained and evaluated identically on the scaled features.","metadata":{}},{"id":"929ed557","cell_type":"markdown","source":"### 9.1 Logistic Regression\n\nA strong, interpretable linear baseline for binary classification.","metadata":{}},{"id":"3c03afea","cell_type":"code","source":"log_reg, log_pred, log_proba, log_metrics = evaluate_model(\n    LogisticRegression(max_iter=5000, random_state=RANDOM_STATE),\n    \"Logistic Regression\", X_train_scaled, X_test_scaled, y_train, y_test\n)","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:37.553519Z","iopub.execute_input":"2026-07-16T12:13:37.554354Z","iopub.status.idle":"2026-07-16T12:13:37.603195Z","shell.execute_reply.started":"2026-07-16T12:13:37.554321Z","shell.execute_reply":"2026-07-16T12:13:37.602494Z"},"trusted":true},"outputs":[{"name":"stdout","text":"📌 Logistic Regression\n   Accuracy  : 0.9649\n   Precision : 0.9750\n   Recall    : 0.9286\n   F1 Score  : 0.9512\n   ROC-AUC   : 0.9960\n   Confusion Matrix:\n[[71  1]\n [ 3 39]]\n--------------------------------------------------\n","output_type":"stream"}],"execution_count":23},{"id":"4b19b127","cell_type":"markdown","source":"### 9.2 K-Nearest Neighbors (KNN)\n\nClassifies a point by majority vote among its `k` closest neighbors in feature space — this is exactly why scaling mattered above.","metadata":{}},{"id":"2d4bd6a8","cell_type":"code","source":"knn_model, knn_pred, knn_proba, knn_metrics = evaluate_model(\n    KNeighborsClassifier(n_neighbors=5),\n    \"K-Nearest Neighbors\", X_train_scaled, X_test_scaled, y_train, y_test\n)","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:41.404029Z","iopub.execute_input":"2026-07-16T12:13:41.40483Z","iopub.status.idle":"2026-07-16T12:13:41.476299Z","shell.execute_reply.started":"2026-07-16T12:13:41.404799Z","shell.execute_reply":"2026-07-16T12:13:41.475455Z"},"trusted":true},"outputs":[{"name":"stdout","text":"📌 K-Nearest Neighbors\n   Accuracy  : 0.9561\n   