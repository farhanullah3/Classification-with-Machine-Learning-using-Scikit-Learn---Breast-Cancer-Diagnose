7Z"},"trusted":true},"outputs":[{"name":"stdout","text":"📌 Random Forest\n   Accuracy  : 0.9737\n   Precision : 1.0000\n   Recall    : 0.9286\n   F1 Score  : 0.9630\n   ROC-AUC   : 0.9929\n   Confusion Matrix:\n[[72  0]\n [ 3 39]]\n--------------------------------------------------\n","output_type":"stream"}],"execution_count":26},{"id":"38831dbd","cell_type":"markdown","source":"### 9.5 Support Vector Machine (SVM)\n\nFinds the maximum-margin boundary between classes; `probability=True` enables ROC-AUC scoring.","metadata":{}},{"id":"418a6815","cell_type":"code","source":"svm_model, svm_pred, svm_proba, svm_metrics = evaluate_model(\n    SVC(probability=True, random_state=RANDOM_STATE),\n    \"Support Vector Machine\", X_train_scaled, X_test_scaled, y_train, y_test\n)","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:50.898065Z","iopub.execute_input":"2026-07-16T12:13:50.898775Z","iopub.status.idle":"2026-07-16T12:13:50.948979Z","shell.execute_reply.started":"2026-07-16T12:13:50.898742Z","shell.execute_reply":"2026-07-16T12:13:50.948143Z"},"trusted":true},"outputs":[{"name":"stdout","text":"📌 Support Vector Machine\n   Accuracy  : 0.9737\n   Precision : 1.0000\n   Recall    : 0.9286\n   F1 Score  : 0.9630\n   ROC-AUC   : 0.9947\n   Confusion Matrix:\n[[72  0]\n [ 3 39]]\n--------------------------------------------------\n","output_type":"stream"}],"execution_count":27},{"id":"7cd1d9b5","cell_type":"markdown","source":"### 9.6 Naive Bayes\n\nA fast, probabilistic baseline that assumes feature independence — a strong assumption here given the multicollinearity we saw in EDA, making it a useful lower-bound comparison.","metadata":{}},{"id":"96db67e3","cell_type":"code","source":"nb_model, nb_pred, nb_proba, nb_metrics = evaluate_model(\n    GaussianNB(),\n    \"Naive Bayes\", X_train_scaled, X_test_scaled, y_train, y_test\n)","metadata":{"execution":{"iopub.status.busy":"2026-07-16T12:13:55.298628Z","iopub.execute_input":"2026-07-16T12:13:55.299385Z","i